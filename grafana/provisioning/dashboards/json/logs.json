{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Error Logs Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"geodata-backend\"} |= \"ERROR\" [5m]))",
          "legendFormat": "Error Count",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"geodata-backend\"} |= \"WARNING\" [5m]))",
          "legendFormat": "Warning Count",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error Count" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Warning Count" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Recent Error Log Lines",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"geodata-backend\"} |= \"ERROR\" | logfmt",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        }
      }
    },
    {
      "title": "Log Volume by Level",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"geodata-backend\"} |= \"ERROR\" [$__range]))",
          "legendFormat": "ERROR",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({job=\"geodata-backend\"} |= \"WARNING\" [$__range]))",
          "legendFormat": "WARNING",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({job=\"geodata-backend\"} |= \"INFO\" [$__range]))",
          "legendFormat": "INFO",
          "refId": "C"
        },
        {
          "expr": "sum(count_over_time({job=\"geodata-backend\"} |= \"DEBUG\" [$__range]))",
          "legendFormat": "DEBUG",
          "refId": "D"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      }
    },
    {
      "title": "Log Volume by Container",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".+\"} [$__range])) by (container)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      }
    },
    {
      "title": "Live Log Stream (Backend)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"geodata-backend\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["geodata", "loki", "logs"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GeoData Logs",
  "uid": "geodata-logs",
  "version": 1
}
